# ── Server ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=3456

# ── Model ───────────────────────────────────────────────
MIMO_MODEL=mimo/mimo-auto

# ── Auth (оставьте пустым для отключения) ───────────────
API_KEY=

# ── CORS (через запятую, * = все) ───────────────────────
CORS_ORIGINS=*

# ── Rate Limiting (запросов на окно) ────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
